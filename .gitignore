# =============================================================================
# Task Arithmetic — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Offline cache (populated by Scripts/download_all.py on the login node)
# Contains HuggingFace models, BEIR datasets, and BM25 index files.
# These can be GBs in size — never commit them.
# -----------------------------------------------------------------------------
offline_cache/

# -----------------------------------------------------------------------------
# Experiment results (generated by Scripts/run_on_gpunode.sh on gpunode1)
# -----------------------------------------------------------------------------
Scripts/results/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distributions / packaging
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
wheels/
*.whl
sdist/
var/
lib/
lib64/
parts/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
Pipfile.lock

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytest.ini

# -----------------------------------------------------------------------------
# Jupyter / IPython
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints/
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
# HuggingFace / Transformers artefacts
# (in case any script caches inside the repo root)
# -----------------------------------------------------------------------------
.cache/
huggingface/
transformers_cache/
hf_cache/
*.bin          # raw model weights
*.safetensors  # safetensors model weights
*.ot           # OpenVINO / ONNX tokenizer
*.msgpack

# -----------------------------------------------------------------------------
# BEIR / IR datasets
# (in case downloaded directly into the repo instead of offline_cache/)
# -----------------------------------------------------------------------------
datasets/
beir_datasets/
*.zip          # downloaded dataset archives before extraction

# -----------------------------------------------------------------------------
# Elasticsearch (setup_elasticsearch.sh)
# -----------------------------------------------------------------------------
elasticsearch*/
elasticsearch-*/
es_data/
es_logs/
*.log          # Elasticsearch + experiment logs

# -----------------------------------------------------------------------------
# Conda / pip environment artefacts
# -----------------------------------------------------------------------------
conda-meta/
*.conda
*.tar.bz2

# -----------------------------------------------------------------------------
# OS / Editor
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# VS Code
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.iws

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.orig
